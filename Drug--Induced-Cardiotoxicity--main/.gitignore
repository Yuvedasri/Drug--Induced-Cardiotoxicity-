# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Keep directory structure but ignore contents
!outputs/.gitkeep
!data/.gitkeep

# Keep example outputs for documentation
!outputs/example_*.png
